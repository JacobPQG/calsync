# ─── CalSync environment variables ───────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real credentials.
#
# Without these variables the app runs in localStorage-only mode
# (no backend, no auth, data stays in the browser).
# ─────────────────────────────────────────────────────────────────────────────

# Find these in: Supabase Dashboard → Project Settings → API
# The anon key is safe to expose in the client bundle; all protection comes
# from Row Level Security (see db/schema/). The service_role key must
# NEVER appear here or anywhere in the frontend.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Domain used for synthetic account emails (<username>@<domain>), for users who
# sign up with a username rather than their own email address.
# These addresses are never mailed — pick any domain you control.
#
# Must NOT be a reserved TLD (.invalid, .test, .example, .localhost): Supabase
# Auth rejects those outright with "Email address is invalid". The address only
# has to LOOK deliverable; it never has to be.
# Optional; defaults to calsync.local.
VITE_ACCOUNT_DOMAIN=calsync.local

# How long a QR invite stays claimable, in hours. Optional; defaults to 72.
# The admin can override it per-invite in the app; this is what the form
# pre-selects. Expiry is enforced in Postgres, not the browser.
VITE_INVITE_LIFETIME_HOURS=72
